extends layout

block content
  h1 Register
  
  if error
   p.error=error

  form(action="/register" method="POST")

    div
      label Username

    div
      input(
        type="text"
        name="username"
      )

    br

    div
      label Email

    div
      input(
        type="email"
        name="email"
      )

    br

    div
      label Password

    div
      input(
        type="password"
        name="password"
      )

    br

    button(type="submit") Register