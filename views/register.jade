extends layout

block content
  .auth-container

    .auth-brand
      h1 Task Manager
      p.tagline
        | Organize your work, track your progress,
        | and stay productive every day.

      .feature-list
        p ✓ Create and manage tasks
        p ✓ Track daily goals
        p ✓ Stay organized anywhere

    .auth-card
      h2 Create Account

      p.subtitle
        | Sign up to start managing your tasks.

      if error
        p.error= error

      form(action="/register" method="POST")

        .form-group
          label(for="username") Username
          input(
            type="text"
            id="username"
            name="username"
            placeholder="Enter your username"
            required
          )

        .form-group
          label(for="email") Email Address
          input(
            type="email"
            id="email"
            name="email"
            placeholder="Enter your email"
            required
          )

        .form-group
          label(for="password") Password
          input(
            type="password"
            id="password"
            name="password"
            placeholder="Create a password"
            required
          )

        button.auth-btn(type="submit")
          | Create Account

      p.login-link
        | Already have an account?
        a(href="/login") Login